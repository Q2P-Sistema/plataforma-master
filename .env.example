# =============================================================================
# Atlas — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# =============================================================================

# --- Banco de Dados (Postgres) ---
DATABASE_URL=postgresql://atlas:atlas_dev@localhost:5432/atlas_dev

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Sessão ---
SESSION_SECRET=troque-por-string-aleatoria-longa-em-producao

# --- Seed do Admin Inicial ---
SEED_ADMIN_EMAIL=admin@atlas.local
SEED_ADMIN_PASSWORD=TroqueEstaSenha123!

# --- n8n Health Check ---
# URL do health check do n8n (opcional em dev)
# N8N_HEALTH_URL=http://localhost:5678/healthz

# --- Sendgrid (e-mail transacional) ---
# Em dev, e-mails são logados no console em vez de enviados
# SENDGRID_API_KEY=SG.sua-chave-aqui
# SENDGRID_FROM_EMAIL=atlas@suaempresa.com.br

# --- Feature Flags de Módulos ---
# Habilite módulos conforme forem ficando prontos
MODULE_HEDGE_ENABLED=false
MODULE_STOCKBRIDGE_ENABLED=false
MODULE_BREAKINGPOINT_ENABLED=false
MODULE_CLEVEL_ENABLED=false
MODULE_COMEXINSIGHT_ENABLED=false
MODULE_COMEXFLOW_ENABLED=false
MODULE_FORECAST_ENABLED=false

# --- Server ---
API_PORT=3005
WEB_PORT=5173
NODE_ENV=development

# --- StockBridge — Integração OMIE (dual-CNPJ) ---
# Necessário quando MODULE_STOCKBRIDGE_ENABLED=true.
# Em dev sem credenciais reais, use OMIE_MODE=mock para respostas sintéticas.
OMIE_MODE=mock
OMIE_API_URL=https://app.omie.com.br/api/v1/
# OMIE_ACXE_KEY=
# OMIE_ACXE_SECRET=
# OMIE_Q2P_KEY=
# OMIE_Q2P_SECRET=

# Chave compartilhada entre n8n e Atlas para o endpoint de saídas automáticas
# ATLAS_INTEGRATION_KEY=troque-por-string-aleatoria-longa

# --- StockBridge — MySQL Legado (apenas para migração one-shot) ---
# Usado somente pelo script `pnpm --filter @atlas/stockbridge migrate-from-mysql`.
# Não é necessário em operação normal do módulo.
# MYSQL_Q2P_HOST=database-01
# MYSQL_Q2P_PORT=3306
# MYSQL_Q2P_USER=claude_readonly
# MYSQL_Q2P_PASS=
# MYSQL_Q2P_DB=db_q2p
